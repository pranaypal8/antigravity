# ============================================================
# SPECIAL ONE — ENVIRONMENT VARIABLES
# ============================================================
# INSTRUCTIONS: Copy this file and rename it to ".env"
# Fill in every value below. Never commit the .env file to Git.
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
# The port your server will run on locally.
# Default 5000 is fine for local development.
PORT=5000

# Your website's URL. For local dev, use http://localhost:5000
# When deployed, change to https://specialone.in
FRONTEND_URL=http://localhost:5000

# ── MongoDB Atlas ────────────────────────────────────────────
# ⚠️ INSERT YOUR MONGODB CONNECTION STRING HERE
# How to get this:
#   1. Go to https://cloud.mongodb.com
#   2. Create a free cluster (M0 Sandbox)
#   3. Click "Connect" → "Drivers" → copy the connection string
#   4. Replace <username> and <password> with your Atlas credentials
#   5. Replace <dbname> with: specialone
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/specialone?retryWrites=true&w=majority

# ── JWT (Login Tokens) ───────────────────────────────────────
# ⚠️ GENERATE YOUR OWN SECRET HERE
# This is a secret password used to sign login tokens.
# How to generate: open terminal and run:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Paste the result below.
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long_replace_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_minimum_64_characters_long_replace_this
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# ── Razorpay (Payments) ──────────────────────────────────────
# ⚠️ INSERT YOUR RAZORPAY CREDENTIALS HERE
# How to find these:
#   1. Log into https://dashboard.razorpay.com
#   2. Go to Settings → API Keys
#   3. Generate a new key pair
#   4. Copy Key ID and Key Secret below
# For testing: use your TEST mode keys (start with rzp_test_)
# For live payments: use LIVE mode keys (start with rzp_live_)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Shiprocket (Delivery) ────────────────────────────────────
# ⚠️ INSERT YOUR SHIPROCKET CREDENTIALS HERE
# How to find these:
#   1. Log into https://app.shiprocket.in
#   2. Go to Settings → API → Generate Token
#   3. Use your Shiprocket login email and password below
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_CHANNEL_ID=your_channel_id

# ── Email (Order Confirmations) ──────────────────────────────
# ⚠️ INSERT YOUR EMAIL CREDENTIALS HERE
# We use Gmail for sending emails. How to set up:
#   1. Go to your Google Account → Security → 2-Step Verification (enable it)
#   2. Then go to App Passwords → generate a password for "Mail"
#   3. Use that 16-character app password below (NOT your regular Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@specialone.in
SMTP_PASS=your_gmail_app_password_16_chars
EMAIL_FROM="Special One <support@specialone.in>"

# ── Admin Seed ───────────────────────────────────────────────
# Password for the first Super Admin account created by the seed script.
# ⚠️ CHANGE THIS IMMEDIATELY after running the seed script.
SEED_ADMIN_EMAIL=specialonepranay@gmail.com
SEED_ADMIN_PASSWORD=SpecialOne@2024!

# ── Environment ──────────────────────────────────────────────
# "development" for local testing, "production" for live server
NODE_ENV=development
